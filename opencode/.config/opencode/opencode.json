{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": false,
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5-xhigh": {
          "id": "gpt-5.5",
          "options": {
            "reasoningEffort": "xhigh"
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "opencode-go/minimax-m3"
    },
    "plan": {
      "model": "openai/gpt-5.5-xhigh"
    },
    "general": {
      "model": "opencode-go/minimax-m3"
    }
  },
  "plugin": ["opencode-mem"],
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      "coverage/**",
      "storage/logs/**",
      "var/cache/**"
    ]
  }
}
