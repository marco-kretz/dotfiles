{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": false,
  "agent": {
    "build": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high"
    },
    "general": {
      "model": "openai/gpt-5.4-fast",
      "reasoningEffort": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      "coverage/**",
      "storage/logs/**",
      "var/cache/**"
    ]
  }
}
